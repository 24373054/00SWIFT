# SWIFT Developer Testing System — environment configuration.
# Copy to `.env` and adjust. All settings are read by backend/config.py.

# === Environment mode ===
# sandbox  = fully local mock (self-signed CA, no real SWIFT calls)
# pilot    = real SWIFT sandbox hosts (requires real PKI cert)
# live     = real SWIFT production (strict PKI, startup confirmation)
SWIFT_ENV=sandbox

# === Server ===
HOST=127.0.0.1
PORT=8765


# === Browser and audit boundaries ===
# Comma-separated origins. Do not use * with credentialed browsers.
CORS_ORIGINS=http://127.0.0.1:8765,http://localhost:8765
# Maximum request-body bytes retained in redacted audit records.
AUDIT_BODY_LIMIT=4096

# === Database ===
DB_URL=sqlite:///swift_dev.db

# === PKI / certificates ===
CERTS_DIR=certs
# Path to the CA bundle used to verify client certs in sandbox mode (mock CA).
# In pilot/live this should point to the real SWIFT CA bundle.
SWIFT_CA_PATH=

# === OAuth ===
# Access token lifetime in seconds (real SWIFT tokens are typically 3600).
OAUTH_TOKEN_TTL_DEFAULT=3600
# Clock-skew tolerance in seconds for token expiry checks.
CLOCK_SKEW_SECONDS=10
# How long to keep JTI replay-protection records (seconds).
JTI_TTL_SECONDS=3660

# === Internal /api/* admin auth ===
# Token required for all /api/* management endpoints. Empty = allowed only in sandbox.
ADMIN_API_TOKEN=

# === Live-mode hosts (only used when SWIFT_ENV=pilot or live) ===
LIVE_HOST_OAUTH=
LIVE_HOST_PREVAL=
LIVE_HOST_SWIFTREF=
LIVE_HOST_TRACKER=
LIVE_HOST_MESSAGING=

# === HTTP client (for live forwarding) ===
# HTTP(S) proxy for outbound calls to real SWIFT (leave empty for direct).
PROXY=
ENABLE_HTTP_LOGS=false
